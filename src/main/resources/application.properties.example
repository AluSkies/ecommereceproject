# ========================================
# Tempus E-commerce API — Configuration
# ========================================
# Copy this file to `application.properties` and complete the values.
# Never commit the real application.properties with production secrets.

spring.application.name=demo
server.port=4002

# ---------- Database (MySQL) ----------
# Defaults match docker-compose.yml — si usás el compose del repo, no hace falta cambiar nada.
spring.datasource.url=jdbc:mysql://localhost:3306/ecommerce_bd
spring.datasource.username=administrator
spring.datasource.password=admin1234
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ---------- JPA / Hibernate ----------
# Use `update` during development; switch to `validate` in prod after running schema.sql manually.
spring.jpa.hibernate.ddl-auto=update
# Uncomment to debug generated SQL:
#spring.jpa.show-sql=true
#spring.jpa.properties.hibernate.format_sql=true

# ---------- JWT ----------
# Generate a fresh base64-encoded key of at least 256 bits for every environment:
#   openssl rand -base64 64
# Do NOT reuse the example value below in production.
application.jwt.secret=replace_with_base64_encoded_256bit_or_longer_key
# Token lifetime in milliseconds (3600000 = 1 hour).
application.jwt.expiration-ms=3600000
