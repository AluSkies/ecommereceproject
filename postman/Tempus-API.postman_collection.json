              "mode": "raw",
              "raw": "{\n  \"sku\": \"FORBIDDEN-001\",\n  \"name\": \"No debería crearse\",\n  \"price\": 100,\n  \"stock\": 1,\n  \"category\": \"SPORT\",\n  \"brandId\": 1\n}"
