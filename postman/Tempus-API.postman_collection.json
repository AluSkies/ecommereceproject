    {
      "name": "Products — Admin",
      "description": "CRUD de productos — requiere token con ROLE_ADMIN. Ejecutar primero 'Login Admin'.",
      "item": [
        {
          "name": "Create product (ADMIN)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"TEST-{{$timestamp}}\",\n  \"name\": \"Reloj de prueba\",\n  \"slug\": \"reloj-prueba-{{$timestamp}}\",\n  \"description\": \"Creado desde Postman\",\n  \"price\": 299.99,\n  \"compareAtPrice\": 349.99,\n  \"stock\": 10,\n  \"category\": \"SPORT\",\n  \"brandId\": 1,\n  \"caliber\": \"Cuarzo\",\n  \"caseSize\": \"42mm\",\n  \"strapMaterial\": \"Acero\",\n  \"images\": [\n    { \"url\": \"https://example.com/test.jpg\", \"sortOrder\": 1, \"altText\": \"Test\" }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/products", "host": ["{{baseUrl}}"], "path": ["api","v1","products"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 creado', function () { pm.response.to.have.status(201); });",
                  "if (pm.response.code === 201) {",
                  "    const id = pm.response.json().id;",
                  "    pm.collectionVariables.set('productId', id);",
                  "    console.log('productId actualizado a', id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update product (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"TEST-UPDATED\",\n  \"name\": \"Reloj actualizado\",\n  \"description\": \"Actualizado desde Postman\",\n  \"price\": 399.99,\n  \"stock\": 15,\n  \"category\": \"SPORT\",\n  \"brandId\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","products","{{productId}}"] }
          }
        },
        {
          "name": "Update price (ADMIN)",
